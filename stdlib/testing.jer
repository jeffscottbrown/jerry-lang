// testing — unit test assertion library.
//
// Used automatically by `jerry test`. Test files should not include this
// directly; the test runner injects `include @testing` into the generated main.
//
// Assertions do not abort on failure — all test functions run to completion.
// test_summary() is called automatically at the end of a test run.

let _test_failures: int = 0;
let _test_passes: int = 0;

fn assert_true(cond: bool, msg: string): void {
    if cond {
        _test_passes = _test_passes + 1;
    } else {
        _test_failures = _test_failures + 1;
        print("  FAIL: " + msg);
    }
}

fn assert_false(cond: bool, msg: string): void {
    if !cond {
        _test_passes = _test_passes + 1;
    } else {
        _test_failures = _test_failures + 1;
        print("  FAIL: " + msg + " (expected false, got true)");
    }
}

fn assert_eq_int(a: int, b: int, msg: string): void {
    if a == b {
        _test_passes = _test_passes + 1;
    } else {
        _test_failures = _test_failures + 1;
        print("  FAIL: " + msg + " (expected " + int_to_string(b) + ", got " + int_to_string(a) + ")");
    }
}

fn assert_eq_string(a: string, b: string, msg: string): void {
    if a == b {
        _test_passes = _test_passes + 1;
    } else {
        _test_failures = _test_failures + 1;
        print("  FAIL: " + msg + " (expected \"" + b + "\", got \"" + a + "\")");
    }
}

fn assert_eq_bool(a: bool, b: bool, msg: string): void {
    if a == b {
        _test_passes = _test_passes + 1;
    } else {
        _test_failures = _test_failures + 1;
        print("  FAIL: " + msg + " (expected " + bool_to_string(b) + ", got " + bool_to_string(a) + ")");
    }
}

fn assert_eq_float(a: float, b: float, msg: string): void {
    if a == b {
        _test_passes = _test_passes + 1;
    } else {
        _test_failures = _test_failures + 1;
        print("  FAIL: " + msg + " (expected " + float_to_string(b) + ", got " + float_to_string(a) + ")");
    }
}

fn test_summary(): void {
    let total: int = _test_passes + _test_failures;
    if _test_failures == 0 {
        print(int_to_string(total) + " passed");
    } else {
        print(int_to_string(_test_passes) + " passed, " + int_to_string(_test_failures) + " failed");
        exit(1);
    }
}
