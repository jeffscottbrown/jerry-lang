// tests/arrays_test.jer — array creation, indexing, mutation, and push
include "github.com/jeffscottbrown/jerry-testing"

fn array_sum(nums: int[]): int {
    let total: int = 0;
    let i: int = 0;
    while i < len(nums) {
        total = total + nums[i];
        i = i + 1;
    }
    return total;
}

fn array_push_in_fn(nums: int[], x: int): void {
    push(nums, x);
}

fn test_creation_and_indexing() {
    let xs: int[] = [10, 20, 30];
    assert_eq_int(len(xs), 3, "initial length");
    assert_eq_int(xs[0], 10, "index 0");
    assert_eq_int(xs[1], 20, "index 1");
    assert_eq_int(xs[2], 30, "index 2");
}

fn test_push() {
    let xs: int[] = [1, 2];
    push(xs, 3);
    assert_eq_int(len(xs), 3, "length after push");
    assert_eq_int(xs[2], 3, "pushed element value");
    push(xs, 4);
    push(xs, 5);
    assert_eq_int(len(xs), 5, "length after two more pushes");
}

fn test_element_mutation() {
    let xs: int[] = [10, 20, 30];
    xs[1] = 99;
    assert_eq_int(xs[0], 10, "first unchanged");
    assert_eq_int(xs[1], 99, "mutated element");
    assert_eq_int(xs[2], 30, "last unchanged");
}

fn test_string_array() {
    let words: string[] = ["foo", "bar", "baz"];
    assert_eq_int(len(words), 3, "string array length");
    assert_eq_string(words[0], "foo", "first");
    assert_eq_string(words[2], "baz", "last");
    push(words, "qux");
    assert_eq_string(words[3], "qux", "pushed string");
}

fn test_bool_array() {
    let flags: bool[] = [true, false, true];
    assert_eq_bool(flags[0], true, "first flag");
    assert_eq_bool(flags[1], false, "second flag");
    flags[1] = true;
    assert_eq_bool(flags[1], true, "mutated flag");
}

fn test_pass_to_function() {
    let xs: int[] = [1, 2, 3, 4, 5];
    assert_eq_int(array_sum(xs), 15, "sum 1-5");
}

fn test_push_via_function() {
    let xs: int[] = [1, 2, 3];
    array_push_in_fn(xs, 99);
    assert_eq_int(len(xs), 4, "push visible from caller");
    assert_eq_int(xs[3], 99, "pushed value visible from caller");
}

fn test_multi_push() {
    let xs: int[] = [1];
    push(xs, 2);
    push(xs, 3);
    push(xs, 4);
    assert_eq_int(len(xs), 4, "length after three pushes");
    assert_eq_int(xs[3], 4, "last pushed element");
}
