// tests/control_flow_test.jer — if/else, while, for, break, continue
include "github.com/jeffscottbrown/jerry-testing"

fn test_if_taken() {
    let result: string = "none";
    if true {
        result = "yes";
    }
    assert_eq_string(result, "yes", "if taken");
}

fn test_if_not_taken() {
    let result: string = "none";
    if false {
        result = "yes";
    }
    assert_eq_string(result, "none", "if not taken");
}

fn test_if_else() {
    let x: int = 5;
    let result: string = "";
    if x > 10 {
        result = "big";
    } else {
        result = "small";
    }
    assert_eq_string(result, "small", "else branch taken");
}

fn test_else_if_chain() {
    let x: int = 7;
    let result: string = "none";
    if x > 10 {
        result = "big";
    } else if x > 5 {
        result = "medium";
    } else {
        result = "small";
    }
    assert_eq_string(result, "medium", "else-if branch");
}

fn test_while_sum() {
    let i: int = 0;
    let sum: int = 0;
    while i < 5 {
        sum = sum + i;
        i = i + 1;
    }
    assert_eq_int(sum, 10, "while sum 0..4");
    assert_eq_int(i, 5, "counter after while");
}

fn test_while_not_entered() {
    let entered: bool = false;
    let i: int = 10;
    while i < 5 {
        entered = true;
        i = i + 1;
    }
    assert_eq_bool(entered, false, "while not entered when cond false");
}

fn test_for_sum() {
    let sum: int = 0;
    for (let i: int = 0; i < 5; i++) {
        sum = sum + i;
    }
    assert_eq_int(sum, 10, "for loop sum 0..4");
}

fn test_for_over_array() {
    let nums: int[] = [10, 20, 30, 40];
    let sum: int = 0;
    for (let i: int = 0; i < len(nums); i++) {
        sum = sum + nums[i];
    }
    assert_eq_int(sum, 100, "for over array");
}

fn test_break() {
    let i: int = 0;
    while true {
        if i == 3 {
            break;
        }
        i = i + 1;
    }
    assert_eq_int(i, 3, "break exits loop at 3");
}

fn test_break_in_for() {
    let found: int = -1;
    let nums: int[] = [5, 10, 15, 20, 25];
    for (let i: int = 0; i < len(nums); i++) {
        if nums[i] == 15 {
            found = i;
            break;
        }
    }
    assert_eq_int(found, 2, "break in for: found index 2");
}

fn test_continue() {
    let sum: int = 0;
    let i: int = 0;
    while i < 6 {
        i = i + 1;
        if i % 2 == 0 {
            continue;
        }
        sum = sum + i;
    }
    // odd numbers 1+3+5 = 9
    assert_eq_int(sum, 9, "continue skips evens");
}

fn test_nested_loops() {
    let count: int = 0;
    for (let i: int = 0; i < 3; i++) {
        for (let j: int = 0; j < 3; j++) {
            count = count + 1;
        }
    }
    assert_eq_int(count, 9, "nested loops 3x3");
}
