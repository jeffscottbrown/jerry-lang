// tests/closures_test.jer — function literals, higher-order functions, void callbacks
include "github.com/jeffscottbrown/jerry-testing"

// Global used as accumulator for void-closure tests (closures don't capture locals).
let _acc: int = 0;

fn apply_int(f: fn(int): int, x: int): int {
    return f(x);
}

fn apply_twice(f: fn(int): int, x: int): int {
    return f(f(x));
}

fn foreach(nums: int[], f: fn(int): void): void {
    for (let i: int = 0; i < len(nums); i++) {
        f(nums[i]);
    }
}

fn sum_with(nums: int[], f: fn(int): int): int {
    let total: int = 0;
    for (let i: int = 0; i < len(nums); i++) {
        total = total + f(nums[i]);
    }
    return total;
}

fn make_doubler(): fn(int): int {
    return fn(x: int): int {
        return x * 2;
    };
}

fn test_function_literal_int() {
    let double = fn(x: int): int { return x * 2; };
    let square = fn(x: int): int { return x * x; };
    assert_eq_int(double(5), 10, "double(5)");
    assert_eq_int(double(0), 0, "double(0)");
    assert_eq_int(square(4), 16, "square(4)");
    assert_eq_int(square(0), 0, "square(0)");
}

fn test_higher_order_apply() {
    let negate = fn(x: int): int { return -x; };
    assert_eq_int(apply_int(negate, 7), -7, "apply negate");
    assert_eq_int(apply_int(negate, -3), 3, "apply negate negative");
}

fn test_apply_twice() {
    let double = fn(x: int): int { return x * 2; };
    assert_eq_int(apply_twice(double, 3), 12, "double applied twice: 3->6->12");
}

fn test_function_return() {
    let doubler = make_doubler();
    assert_eq_int(doubler(5), 10, "returned fn: double 5");
    assert_eq_int(doubler(7), 14, "returned fn: double 7");
}

fn test_sum_with_transform() {
    let nums: int[] = [1, 2, 3, 4, 5];
    let identity = fn(x: int): int { return x; };
    let double = fn(x: int): int { return x * 2; };
    assert_eq_int(sum_with(nums, identity), 15, "sum without transform");
    assert_eq_int(sum_with(nums, double), 30, "sum of doubles");
}

fn test_void_fn_as_callback() {
    _acc = 0;
    let nums: int[] = [1, 2, 3, 4, 5];
    let adder = fn(x: int): void {
        _acc = _acc + x;
    };
    foreach(nums, adder);
    assert_eq_int(_acc, 15, "void closure accumulates 1+2+3+4+5");
}

fn test_void_closure_reset() {
    _acc = 0;
    let nums: int[] = [10, 20, 30];
    let adder = fn(x: int): void {
        _acc = _acc + x;
    };
    foreach(nums, adder);
    assert_eq_int(_acc, 60, "void closure accumulates 10+20+30");
}
