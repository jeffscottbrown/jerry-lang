// tests/functions_test.jer — functions, recursion, multiple return paths
include "github.com/jeffscottbrown/jerry-testing"

fn add(a: int, b: int): int {
    return a + b;
}

fn multiply(a: int, b: int): int {
    return a * b;
}

fn max_of_two(a: int, b: int): int {
    if a > b {
        return a;
    }
    return b;
}

fn sign(n: int): string {
    if n > 0 {
        return "positive";
    } else if n < 0 {
        return "negative";
    }
    return "zero";
}

fn factorial(n: int): int {
    if n <= 1 {
        return 1;
    }
    return n * factorial(n - 1);
}

fn fibonacci(n: int): int {
    if n <= 1 {
        return n;
    }
    return fibonacci(n - 1) + fibonacci(n - 2);
}

fn count_down(n: int): int {
    if n <= 0 {
        return 0;
    }
    return count_down(n - 1) + 1;
}

fn test_basic_functions() {
    assert_eq_int(add(2, 3), 5, "add 2+3");
    assert_eq_int(add(-1, 1), 0, "add -1+1");
    assert_eq_int(add(0, 0), 0, "add 0+0");
    assert_eq_int(multiply(3, 4), 12, "multiply 3*4");
    assert_eq_int(multiply(0, 100), 0, "multiply by zero");
}

fn test_multiple_return_paths() {
    assert_eq_int(max_of_two(5, 3), 5, "max left");
    assert_eq_int(max_of_two(3, 5), 5, "max right");
    assert_eq_int(max_of_two(4, 4), 4, "max equal");
}

fn test_string_return() {
    assert_eq_string(sign(1), "positive", "sign positive");
    assert_eq_string(sign(-1), "negative", "sign negative");
    assert_eq_string(sign(0), "zero", "sign zero");
}

fn test_factorial() {
    assert_eq_int(factorial(0), 1, "0! = 1");
    assert_eq_int(factorial(1), 1, "1! = 1");
    assert_eq_int(factorial(2), 2, "2! = 2");
    assert_eq_int(factorial(5), 120, "5! = 120");
    assert_eq_int(factorial(10), 3628800, "10!");
}

fn test_fibonacci() {
    assert_eq_int(fibonacci(0), 0, "fib(0)");
    assert_eq_int(fibonacci(1), 1, "fib(1)");
    assert_eq_int(fibonacci(2), 1, "fib(2)");
    assert_eq_int(fibonacci(6), 8, "fib(6)");
    assert_eq_int(fibonacci(10), 55, "fib(10)");
}

fn test_tail_recursion() {
    assert_eq_int(count_down(10), 10, "count_down(10)");
    assert_eq_int(count_down(0), 0, "count_down(0)");
}
