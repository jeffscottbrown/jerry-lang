include @testing

// ── map<string, int> ──────────────────────────────────────────────────────────

fn test_set_and_get_string_key() {
    let m: map<string, int> = {};
    m["a"] = 1;
    assert_eq_int(m["a"], 1, "get after set");
}

fn test_overwrite_existing_key() {
    let m: map<string, int> = {};
    m["x"] = 10;
    m["x"] = 99;
    assert_eq_int(m["x"], 99, "overwrite returns new value");
}

fn test_multiple_keys() {
    let m: map<string, int> = {};
    m["alice"] = 30;
    m["bob"]   = 25;
    m["carol"] = 35;
    assert_eq_int(m["alice"], 30, "alice");
    assert_eq_int(m["bob"],   25, "bob");
    assert_eq_int(m["carol"], 35, "carol");
}

fn test_map_len_empty() {
    let m: map<string, int> = {};
    assert_eq_int(map_len(m), 0, "empty map len is 0");
}

fn test_map_len_after_inserts() {
    let m: map<string, int> = {};
    m["a"] = 1;
    m["b"] = 2;
    m["c"] = 3;
    assert_eq_int(map_len(m), 3, "len after 3 inserts");
}

fn test_map_len_overwrite_does_not_grow() {
    let m: map<string, int> = {};
    m["k"] = 1;
    m["k"] = 2;
    assert_eq_int(map_len(m), 1, "overwrite does not increase len");
}

fn test_map_has_present_key() {
    let m: map<string, int> = {};
    m["hi"] = 7;
    assert_eq_bool(map_has(m, "hi"), true, "has present key");
}

fn test_map_has_absent_key() {
    let m: map<string, int> = {};
    assert_eq_bool(map_has(m, "nope"), false, "has absent key");
}

fn test_map_delete_removes_key() {
    let m: map<string, int> = {};
    m["del"] = 42;
    map_delete(m, "del");
    assert_eq_bool(map_has(m, "del"), false, "deleted key not present");
}

fn test_map_delete_reduces_len() {
    let m: map<string, int> = {};
    m["a"] = 1;
    m["b"] = 2;
    map_delete(m, "a");
    assert_eq_int(map_len(m), 1, "len reduced after delete");
}

fn test_map_delete_nonexistent_is_safe() {
    let m: map<string, int> = {};
    m["a"] = 1;
    map_delete(m, "z");
    assert_eq_int(map_len(m), 1, "delete of absent key leaves len unchanged");
}

// ── map<int, string> ──────────────────────────────────────────────────────────

fn test_int_key_set_and_get() {
    let m: map<int, string> = {};
    m[1] = "one";
    m[2] = "two";
    m[3] = "three";
    assert_eq_string(m[2], "two", "int key get");
}

fn test_int_key_has() {
    let m: map<int, string> = {};
    m[42] = "answer";
    assert_eq_bool(map_has(m, 42), true,  "has 42");
    assert_eq_bool(map_has(m, 99), false, "no 99");
}

fn test_int_key_delete() {
    let m: map<int, string> = {};
    m[1] = "a";
    m[2] = "b";
    map_delete(m, 1);
    assert_eq_bool(map_has(m, 1), false, "1 deleted");
    assert_eq_bool(map_has(m, 2), true,  "2 still present");
}

// ── Index operator ────────────────────────────────────────────────────────────

fn test_index_get() {
    let m: map<string, int> = {};
    m["n"] = 77;
    assert_eq_int(m["n"], 77, "index get");
}

fn test_index_set() {
    let m: map<string, int> = {};
    m["k"] = 1;
    m["k"] = 100;
    assert_eq_int(m["k"], 100, "index set overwrites");
}

fn test_index_insert_via_operator() {
    let m: map<string, int> = {};
    m["new"] = 55;
    assert_eq_int(m["new"], 55, "index insert");
    assert_eq_int(map_len(m), 1, "len after index insert");
}

// ── Map literal ───────────────────────────────────────────────────────────────

fn test_map_literal_string_keys() {
    let m: map<string, int> = {"x": 10, "y": 20, "z": 30};
    assert_eq_int(m["x"], 10, "literal x");
    assert_eq_int(m["y"], 20, "literal y");
    assert_eq_int(m["z"], 30, "literal z");
    assert_eq_int(map_len(m), 3, "literal len");
}

fn test_map_literal_int_keys() {
    let m: map<int, int> = {1: 100, 2: 200};
    assert_eq_int(m[1], 100, "int literal 1");
    assert_eq_int(m[2], 200, "int literal 2");
}

// ── map_keys ──────────────────────────────────────────────────────────────────

fn test_map_keys_count() {
    let m: map<string, int> = {"a": 1, "b": 2, "c": 3};
    let keys: string[] = map_keys(m);
    assert_eq_int(len(keys), 3, "map_keys returns all keys");
}

fn test_map_keys_empty_map() {
    let m: map<string, int> = {};
    let keys: string[] = map_keys(m);
    assert_eq_int(len(keys), 0, "map_keys of empty map is empty array");
}

// ── Rehashing stress ──────────────────────────────────────────────────────────

fn test_many_inserts_and_gets() {
    let m: map<string, int> = {};
    // Insert enough to trigger multiple rehashes (default bucket_count=16, rehash at 12)
    m["k0"]  = 0;
    m["k1"]  = 1;
    m["k2"]  = 2;
    m["k3"]  = 3;
    m["k4"]  = 4;
    m["k5"]  = 5;
    m["k6"]  = 6;
    m["k7"]  = 7;
    m["k8"]  = 8;
    m["k9"]  = 9;
    m["k10"] = 10;
    m["k11"] = 11;
    m["k12"] = 12;
    m["k13"] = 13;
    m["k14"] = 14;
    m["k15"] = 15;
    m["k16"] = 16;
    m["k17"] = 17;
    m["k18"] = 18;
    m["k19"] = 19;
    assert_eq_int(map_len(m), 20, "20 inserts");
    assert_eq_int(m["k0"],  0,  "k0 after rehash");
    assert_eq_int(m["k10"], 10, "k10 after rehash");
    assert_eq_int(m["k19"], 19, "k19 after rehash");
}
