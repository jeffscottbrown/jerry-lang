// tests/strings_test.jer — built-in string operations
include @testing

fn test_concat() {
    assert_eq_string("hello" + " " + "world", "hello world", "three-part concat");
    assert_eq_string("" + "abc", "abc", "empty left");
    assert_eq_string("abc" + "", "abc", "empty right");
    assert_eq_string("" + "", "", "both empty");
}

fn test_len() {
    assert_eq_int(len("hello"), 5, "len hello");
    assert_eq_int(len(""), 0, "len empty");
    assert_eq_int(len("a"), 1, "len single char");
    assert_eq_int(len("jerry lang"), 10, "len with space");
}

fn test_slice() {
    assert_eq_string(string_slice("hello", 0, 3), "hel", "slice 0-3");
    assert_eq_string(string_slice("hello", 1, 4), "ell", "slice 1-4");
    assert_eq_string(string_slice("hello", 0, 5), "hello", "full slice");
    assert_eq_string(string_slice("hello", 2, 2), "", "zero-length slice");
}

fn test_char_at() {
    // ASCII: 'h'=104, 'e'=101, 'l'=108, 'o'=111
    assert_eq_int(char_at("hello", 0), 104, "char_at h");
    assert_eq_int(char_at("hello", 1), 101, "char_at e");
    assert_eq_int(char_at("hello", 4), 111, "char_at o");
}

fn test_int_to_string() {
    assert_eq_string(int_to_string(0), "0", "zero");
    assert_eq_string(int_to_string(42), "42", "positive");
    assert_eq_string(int_to_string(-7), "-7", "negative");
    assert_eq_string(int_to_string(1000000), "1000000", "large");
}

fn test_float_to_string() {
    assert_eq_string(float_to_string(0.0), "0", "zero float");
    assert_eq_string(float_to_string(3.14), "3.14", "pi-ish");
    assert_eq_string(float_to_string(1.5), "1.5", "one point five");
    assert_eq_string(float_to_string(100.0), "100", "whole number float");
}

fn test_bool_to_string() {
    assert_eq_string(bool_to_string(true), "true", "true");
    assert_eq_string(bool_to_string(false), "false", "false");
}

fn test_char_to_string() {
    assert_eq_string(char_to_string(65), "A", "char A");
    assert_eq_string(char_to_string(97), "a", "char a");
    assert_eq_string(char_to_string(48), "0", "char 0");
}

fn test_string_contains() {
    assert_true(string_contains("hello world", "world"), "contains suffix");
    assert_true(string_contains("hello world", "hello"), "contains prefix");
    assert_true(string_contains("hello world", "lo wo"), "contains middle");
    assert_true(string_contains("hello", ""), "contains empty");
    assert_false(string_contains("hello", "xyz"), "not contains");
    assert_false(string_contains("", "a"), "empty haystack");
}

fn test_string_starts_with() {
    assert_true(string_starts_with("hello world", "hello"), "starts with prefix");
    assert_true(string_starts_with("hello", ""), "starts with empty");
    assert_true(string_starts_with("hello", "hello"), "starts with full string");
    assert_false(string_starts_with("hello world", "world"), "does not start with suffix");
    assert_false(string_starts_with("", "a"), "empty string");
}

fn test_string_ends_with() {
    assert_true(string_ends_with("hello world", "world"), "ends with suffix");
    assert_true(string_ends_with("hello", ""), "ends with empty");
    assert_true(string_ends_with("hello", "hello"), "ends with full string");
    assert_false(string_ends_with("hello world", "hello"), "does not end with prefix");
    assert_false(string_ends_with("", "a"), "empty string");
}

fn test_string_index_of() {
    assert_eq_int(string_index_of("hello world", "world"), 6, "index of suffix");
    assert_eq_int(string_index_of("hello world", "hello"), 0, "index of prefix");
    assert_eq_int(string_index_of("hello world", "lo"), 3, "index of middle");
    assert_eq_int(string_index_of("hello world", ""), 0, "index of empty sub");
    assert_eq_int(string_index_of("hello", "xyz"), -1, "index of absent");
    assert_eq_int(string_index_of("", "a"), -1, "index of in empty string");
    assert_eq_int(string_index_of("abcabc", "bc"), 1, "index of first occurrence");
}

fn test_string_to_int() {
    assert_eq_int(string_to_int("0"), 0, "zero");
    assert_eq_int(string_to_int("42"), 42, "positive");
    assert_eq_int(string_to_int("-7"), -7, "negative");
    assert_eq_int(string_to_int("1000000"), 1000000, "large");
    assert_eq_int(string_to_int("  99"), 99, "leading space");
}

fn test_string_equality() {
    assert_true("hello" == "hello", "equal strings");
    assert_false("hello" == "world", "unequal strings");
    assert_true("" == "", "empty strings equal");
    assert_false("" == "a", "empty vs non-empty");
}
