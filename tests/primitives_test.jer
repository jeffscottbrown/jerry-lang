// tests/primitives_test.jer — int, float, and bool operations
include "github.com/jeffscottbrown/jerry-testing"

fn test_int_arithmetic() {
    assert_eq_int(2 + 3, 5, "addition");
    assert_eq_int(10 - 4, 6, "subtraction");
    assert_eq_int(3 * 4, 12, "multiplication");
    assert_eq_int(10 / 3, 3, "integer division truncates");
    assert_eq_int(10 % 3, 1, "modulo");
    assert_eq_int(-5 + 5, 0, "negative addition");
    assert_eq_int(0 - 7, -7, "zero minus positive");
}

fn test_int_comparisons() {
    assert_true(1 < 2, "less than");
    assert_true(2 <= 2, "less than or equal, equal case");
    assert_true(1 <= 2, "less than or equal, less case");
    assert_true(3 > 2, "greater than");
    assert_true(2 >= 2, "greater than or equal, equal case");
    assert_true(3 >= 2, "greater than or equal, greater case");
    assert_true(2 == 2, "equal");
    assert_true(2 != 3, "not equal");
    assert_false(2 > 3, "not greater than");
    assert_false(2 < 2, "not less than equal");
}

fn test_bool_logic() {
    assert_true(true && true, "true && true");
    assert_false(true && false, "true && false");
    assert_false(false && true, "false && true");
    assert_false(false && false, "false && false");
    assert_true(true || false, "true || false");
    assert_true(false || true, "false || true");
    assert_false(false || false, "false || false");
    assert_true(true || true, "true || true");
    assert_true(!false, "!false");
    assert_false(!true, "!true");
}

fn test_float_arithmetic() {
    assert_eq_float(1.5 + 1.5, 3.0, "float addition");
    assert_eq_float(5.0 - 2.5, 2.5, "float subtraction");
    assert_eq_float(2.0 * 3.0, 6.0, "float multiplication");
    assert_eq_float(10.0 / 4.0, 2.5, "float division");
    assert_eq_float(-1.5 + 1.5, 0.0, "float negative addition");
}

fn test_float_comparisons() {
    assert_true(1.0 < 2.0, "float less than");
    assert_true(2.0 > 1.0, "float greater than");
    assert_true(1.5 == 1.5, "float equal");
    assert_true(1.5 != 2.5, "float not equal");
}
